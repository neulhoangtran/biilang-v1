{
  "kind": "collectionType",
  "collectionName": "up_users",
  "info": {
    "name": "user",
    "description": "",
    "singularName": "user",
    "pluralName": "users",
    "displayName": "User"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "username": {
      "type": "string",
      "minLength": 3,
      "unique": true,
      "configurable": false,
      "required": true
    },
    "email": {
      "type": "email",
      "minLength": 6,
      "configurable": false,
      "required": true
    },
    "provider": {
      "type": "string",
      "configurable": false
    },
    "password": {
      "type": "password",
      "minLength": 6,
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "resetPasswordToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmationToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmed": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "blocked": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "role": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.role",
      "inversedBy": "users",
      "configurable": false
    },
    "PhoneNumber": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "DateOfBirth": {
      "type": "date"
    },
    "Sex": {
      "type": "enumeration",
      "enum": [
        "Male",
        "Female"
      ]
    },
    "Branch": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::branch.branch",
      "inversedBy": "Users"
    },
    "FirstName": {
      "type": "string"
    },
    "LastName": {
      "type": "string"
    },
    "Avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "device_tokens": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::device-token.device-token",
      "mappedBy": "User"
    },
    "MarkDelete": {
      "type": "boolean",
      "default": false
    },
    "MarkDeleteDate": {
      "type": "datetime"
    },
    "Notifications": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::notification.notification",
      "inversedBy": "Users"
    },
    "CustomName": {
      "type": "string"
    },
    "IsFirstRegister": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "ExpiredFirstRegisterVoucher": {
      "type": "date"
    },
    "Voucher": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::voucher.voucher",
      "mappedBy": "User"
    },
    "IsUseFirstRegisterVoucher": {
      "type": "boolean",
      "default": false
    },
    "voucher_histories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::voucher-history.voucher-history",
      "private": true,
      "mappedBy": "User"
    },
    "sms_messages": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::sms-message.sms-message",
      "inversedBy": "Users"
    },
    "user_activities": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-activity.user-activity",
      "mappedBy": "User"
    }
  }
}
