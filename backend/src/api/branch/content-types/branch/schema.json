{
  "kind": "collectionType",
  "collectionName": "branches",
  "info": {
    "singularName": "branch",
    "pluralName": "branches",
    "displayName": "Branch"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true
    },
    "Slug": {
      "type": "uid",
      "targetField": "Name",
      "required": true
    },
    "Area": {
      "type": "string"
    },
    "Address": {
      "type": "string"
    },
    "Phone": {
      "type": "string"
    },
    "MapLink": {
      "type": "string"
    },
    "MapImage": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "Zalo": {
      "type": "string",
      "required": true
    },
    "Messenger": {
      "type": "string",
      "required": true
    },
    "Users": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user",
      "mappedBy": "Branch"
    },
    "Notification": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::notification.notification",
      "inversedBy": "Branch"
    },
    "SortOrder": {
      "type": "integer",
      "default": 999,
      "min": 1
    },
    "Voucher": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::voucher.voucher",
      "mappedBy": "Branch"
    },
    "WorkingTime": {
      "type": "string"
    },
    "DayOff": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "sms_messages": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::sms-message.sms-message",
      "inversedBy": "Branches"
    }
  }
}
