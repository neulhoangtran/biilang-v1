{
  "kind": "collectionType",
  "collectionName": "voucher_histories",
  "info": {
    "singularName": "voucher-history",
    "pluralName": "voucher-histories",
    "displayName": "Voucher History"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true
    },
    "Voucher": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::voucher.voucher",
      "inversedBy": "voucher_histories"
    },
    "IsSuccess": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "AppliedDate": {
      "type": "datetime",
      "required": true
    },
    "User": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "private": true,
      "inversedBy": "voucher_histories"
    }
  }
}
