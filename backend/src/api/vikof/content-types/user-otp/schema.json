{
  "kind": "collectionType",
  "collectionName": "vikof_user_otps",
  "info": {
    "singularName": "user-otp",
    "pluralName": "user-otps",
    "displayName": "Vikof User OTP",
    "description": "OTP records for Vikof user registration and login"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "phoneNumber": {
      "type": "string",
      "required": true
    },
    "code": {
      "type": "string",
      "required": true
    },
    "purpose": {
      "type": "enumeration",
      "required": true,
      "default": "register",
      "enum": [
        "register",
        "login",
        "reset_password",
        "verify_phone"
      ]
    },
    "expiresAt": {
      "type": "datetime",
      "required": true
    },
    "used": {
      "type": "boolean",
      "default": false
    },
    "attempt": {
      "type": "integer",
      "default": 0
    }
  }
}
